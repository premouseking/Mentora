{
  "name": "mentora",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "@swc/core"
    ]
  },
  "scripts": {
    "dev:web": "pnpm --dir apps/web dev",
    "dev:api": "bash -lc 'cd apps/api && source .venv/bin/activate && set -a && source ../../.env && set +a && python manage.py migrate --noinput && python manage.py runserver 127.0.0.1:8000'",
    "dev": "concurrently -k -n api,web \"pnpm dev:api\" \"pnpm dev:web\"",
    "build:web": "pnpm --dir apps/web build",
    "typecheck:web": "pnpm --dir apps/web typecheck",
    "test:web": "pnpm --dir apps/web test",
    "dev:desktop": "concurrently -k -n web,app \"pnpm dev:web\" \"pnpm --dir apps/desktop dev\"",
    "build:desktop": "pnpm --dir apps/desktop build",
    "typecheck:desktop": "pnpm --dir apps/desktop typecheck",
    "test:desktop": "pnpm --dir apps/desktop test",
    "smoke:desktop": "pnpm --dir apps/desktop smoke",
    "dist:desktop": "pnpm --dir apps/desktop dist",
    "infra:up": "docker compose -f infra/docker/docker-compose.dev.yml up -d",
    "infra:down": "docker compose -f infra/docker/docker-compose.dev.yml down",
    "api:docker:build": "bash infra/docker/scripts/build_api_image.sh",
    "api:docker:check": "python3 infra/docker/scripts/check_api_image.py --require-container",
    "api:docker:sync": "bash infra/docker/scripts/sync_api_to_container.sh",
    "api:docker:up": "bash infra/docker/scripts/start_api.sh",
    "api:migrate": "bash -lc 'cd apps/api && source .venv/bin/activate && set -a && source ../../.env && set +a && python manage.py migrate --noinput'",
    "api:seed": "cd apps/api && python manage.py seed_dev",
    "api:smoke:upload": "cd apps/api && python manage.py smoke_upload_resource --fixture normal.pdf"
  }
}
