DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api
POSTGRES_DB=mentora
POSTGRES_USER=mentora
POSTGRES_PASSWORD=mentora
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=55432
POSTGRES_CONNECT_TIMEOUT=5
REDIS_URL=redis://127.0.0.1:56379/0
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_BUCKET=mentora
OBJECT_STORAGE_ACCESS_KEY=mentora
OBJECT_STORAGE_SECRET_KEY=mentora-secret
OBJECT_STORAGE_REGION=us-east-1
# 测试/CI 无 MinIO 时使用 filesystem；本地 Docker 开发默认 s3（MinIO）
OBJECT_STORAGE_BACKEND=s3
OBJECT_STORAGE_FS_ROOT=/tmp/mentora/storage
DEV_OWNER_ID=00000000-0000-0000-0000-000000000001
# 浏览器直传 MinIO 的可达地址；云服务器填公网 IP（nginx 转发 /mentora/ → MinIO）
OBJECT_STORAGE_PUBLIC_ENDPOINT=http://124.222.211.202
# 云服务器对外访问（经 nginx 80 端口）
# DJANGO_ALLOWED_HOSTS=<公网IP>,localhost,127.0.0.1,api
# MENTORA_API_BASE_URL=http://<公网IP>/api
# VITE_WS_BASE_URL=ws://<公网IP>/ws
VITE_API_BASE_URL=http://127.0.0.1:8000/api
VITE_WS_BASE_URL=ws://127.0.0.1:8000/ws
# 演示/联调时设为 true，建课流程跳过 AI 追问环节
# VITE_SKIP_COURSE_INQUIRY=true
# Electron 桌面宿主（apps/desktop）。`pnpm dev:desktop` 会自动设置
# MENTORA_DEV_SERVER_URL。main/preload 变更时 nodemon 重启 Electron；
# renderer 热更新由 Vite dev server 提供。可覆盖 MENTORA_API_BASE_URL 指向非本地后端。
MENTORA_API_BASE_URL=http://127.0.0.1:8000/api
# 未打包开发态默认跳过认证门禁。设为 0 可验证完整登录/注册流程。
# MENTORA_DEV_AUTH_BYPASS=0
# ── LLM 配置 ──
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_FAST=gpt-4o-mini
LLM_MODEL_BALANCED=gpt-4o-mini
LLM_MODEL_PREMIUM=gpt-4o
LLM_MAX_TOKENS=16384
LLM_TEMPERATURE=0.7
LLM_MAX_RETRIES=1
LLM_REQUEST_TIMEOUT=120
LLM_STRUCTURED_TIMEOUT=300
LLM_STREAM_TIMEOUT=120

# ── 豆包 Embedding / 多模态（火山方舟）──
# VOLCANO_ENGINE_API_KEY=
# EMBEDDING_DOUBAO_MODEL=doubao-embedding-vision-250615
# EMBEDDING_DOUBAO_DIMENSIONS=2000
# EMBEDDING_DOUBAO_ENDPOINT_ID=ep-m-xxxxxxxx
# MULTIMODAL_API_KEY=
