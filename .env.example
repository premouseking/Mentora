DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=true
POSTGRES_DB=mentora
POSTGRES_USER=mentora
POSTGRbiao zhuES_PASSWORD=mentora
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=55432
REDIS_URL=redis://127.0.0.1:6379/0
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_BUCKET=mentora
OBJECT_STORAGE_ACCESS_KEY=mentora
OBJECT_STORAGE_SECRET_KEY=mentora-secret
OBJECT_STORAGE_REGION=us-east-1
# 测试/CI 无 MinIO 时使用 filesystem；本地 Docker 开发默认 s3（MinIO）
OBJECT_STORAGE_BACKEND=s3
OBJECT_STORAGE_FS_ROOT=/tmp/mentora/storage
VITE_API_BASE_URL=http://127.0.0.1:8000/api
VITE_WS_BASE_URL=ws://127.0.0.1:8000/ws
# Electron 桌面宿主（apps/desktop）。`pnpm dev:desktop` 会自动设置
# MENTORA_DEV_SERVER_URL。main/preload 变更时 nodemon 重启 Electron；
# renderer 热更新由 Vite dev server 提供。可覆盖 MENTORA_API_BASE_URL 指向非本地后端。
MENTORA_API_BASE_URL=http://127.0.0.1:8000/api
# 未打包开发态默认跳过认证门禁。设为 0 可验证完整登录/注册流程。
# MENTORA_DEV_AUTH_BYPASS=0
# ── LLM 配置 ──
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_FAST=gpt-4o-mini
LLM_MODEL_BALANCED=gpt-4o-mini
LLM_MODEL_PREMIUM=gpt-4o
LLM_MAX_TOKENS=16384
LLM_TEMPERATURE=0.7
LLM_MAX_RETRIES=1
LLM_REQUEST_TIMEOUT=30
LLM_STREAM_TIMEOUT=120
